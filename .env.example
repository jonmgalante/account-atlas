# Account Atlas
# Required for server-side persistence and Drizzle migrations.
DATABASE_URL=postgresql://TODO_USER:TODO_PASSWORD@TODO_HOST:5432/account_atlas

# Recommended for production so requester fingerprints are salted consistently.
REQUEST_FINGERPRINT_SALT=TODO_LONG_RANDOM_STRING

# Legacy pipeline mode:
# - New reports use the single deep-research background job path.
# - Keep this only for legacy pipeline validation or rollback testing.
# - auto: use Vercel Queues on Vercel, inline mode locally
# - inline: always run jobs in-process
# - vercel_queue: require queue delivery and disable inline fallback
REPORT_PIPELINE_MODE=auto

# Public app abuse controls
REPORT_CREATE_RATE_LIMIT_MAX=8
REPORT_CREATE_RATE_LIMIT_WINDOW_MS=3600000
REPORT_DOMAIN_ACTIVE_COOLDOWN_MS=1800000
REPORT_DOMAIN_FAILED_COOLDOWN_MS=900000
REPORT_RECENT_REUSE_WINDOW_MS=86400000

# Crawl limits and timeouts
CRAWL_MAX_HTML_PAGES=12
CRAWL_MAX_PDF_LINKS=6
CRAWL_MAX_CONCURRENCY=2
CRAWL_REQUEST_TIMEOUT_MS=12000
CRAWL_MAX_RESPONSE_BYTES=1500000
CRAWL_MAX_PDF_BYTES=4000000

# Required for the OpenAI Responses deep-research background job and report synthesis.
OPENAI_API_KEY=TODO_OPENAI_API_KEY

# Optional locally. Required if you want Blob-backed source/export artifacts.
BLOB_READ_WRITE_TOKEN=TODO_VERCEL_BLOB_READ_WRITE_TOKEN
